public class Main {
    public static void main(String[] args) {
        int rows = 5; // Total  pyramid

        for (int i = 1; i <= rows; i++) {
          
            for (int j = i; j < rows; j++) {
                System.out.print(" ");
            }

            
            for (int k = 1; k <= (2 * i - 1); k++) {
                System.out.print("*");
            }

            // 3. Move to the next line
            System.out.println();
        }
    }
}
