public class ReversePyramid {
    public static void main(String[] args) {
        int rows = 5; // Total rows for the reverse pyramid

        // Outer loop handles the rows, counting down from total rows to 1
        for (int i = rows; i >= 1; i--) {
            
            // First inner loop prints the leading spaces for alignment
            for (int j = 1; j <= rows - i; j++) {
                System.out.print(" ");
            }
            
            // Second inner loop number of stars (2 * i - 1)
            for (int k = 1; k <= (2 * i - 1); k++) {
                System.out.print("*");
            }
            
          
            System.out.println();
        }
    }
}
